#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
RUMB_HOME=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
export RUMB_HOME
export RUMB_MCP_SHIM="$SCRIPT_DIR/rumb-mcp"

BINARY="$RUMB_HOME/target/debug/rumb-mcp"

if [ ! -x "$BINARY" ]; then
  cargo build --manifest-path "$RUMB_HOME/Cargo.toml" --bin rumb-mcp >/dev/null
fi

exec "$BINARY" "$@"
